{
  "expo": {
    "name": "Eventa",
    "slug": "Eventa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nils23.Eventa",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Eventa to use your location to find events near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Eventa to use your location to find events near you.",
        "NSCameraUsageDescription": "Allow Eventa to use your camera to record stories at venues.",
        "NSMicrophoneUsageDescription": "Allow Eventa to record audio for your video stories.",
        "NSPhotoLibraryUsageDescription": "Allow Eventa to access your gallery to upload stories.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.653907647305-jfh53up4abu5giju93624umbbpg07ed6"
            ]
          }
        ],
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAMbBDQ3tayrzs26biBBqJVnsuzLRvFsUQ"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nils23.Eventa",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAMbBDQ3tayrzs26biBBqJVnsuzLRvFsUQ"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "@react-native-google-signin/google-signin",
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyAMbBDQ3tayrzs26biBBqJVnsuzLRvFsUQ",
          "iosGoogleMapsApiKey": "AIzaSyAMbBDQ3tayrzs26biBBqJVnsuzLRvFsUQ"
        }
      ]
    ]
  }
}