{
  "expo": {
    "name": "Eventas",
    "slug": "Eventa",
    "version": "1.0.5",
    "scheme": "eventas",
    "orientation": "portrait",
    "icon": "./assets/App_icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "buildNumber": "29",
      "supportsTablet": true,
      "bundleIdentifier": "com.nils23.Eventa",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Eventas uses your location to show you nearby events and venues while the app is active.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Eventas uses your location in the background to update venue discovery when you move significantly, keeping battery consumption minimal.",
        "NSCameraUsageDescription": "Allow Eventas to use your camera to record stories at venues.",
        "NSMicrophoneUsageDescription": "Allow Eventas to record audio for your video stories.",
        "NSPhotoLibraryUsageDescription": "Allow Eventas to access your gallery to upload stories.",
        "LSApplicationQueriesSchemes": [
          "mailto",
          "mailto",
          "mailto",
          "mailto"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.653907647305-jfh53up4abu5giju93624umbbpg07ed6"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.653907647305-jfh53up4abu5giju93624umbbpg07ed6"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.653907647305-jfh53up4abu5giju93624umbbpg07ed6"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.653907647305-jfh53up4abu5giju93624umbbpg07ed6"
            ]
          }
        ],
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:eventas.live",
        "applinks:www.eventas.live"
      ],
      "usesAppleSignIn": true
    },
    "android": {
      "versionCode": 32,
      "adaptiveIcon": {
        "foregroundImage": "./assets/App_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nils23.Eventa",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "eventas.live", "pathPrefix": "/invite" },
            { "scheme": "https", "host": "www.eventas.live", "pathPrefix": "/invite" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-location",
      "@react-native-google-signin/google-signin",
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "",
          "iosGoogleMapsApiKey": ""
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "97c28f7f-bc55-49da-a7d8-7bcccc4fa3e2"
      }
    },
    "owner": "nils-23",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/97c28f7f-bc55-49da-a7d8-7bcccc4fa3e2",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    }
  }
}
