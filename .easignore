# EAS Build upload exclusions.
# NOTE: when .easignore exists, EAS Build uses it INSTEAD of .gitignore —
# every .gitignore entry that should stay out of cloud builds must be
# mirrored here.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native projects (regenerated by prebuild on EAS) and credentials
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Build artifacts — kept in git for archival, never needed by cloud builds.
# This is the main archive-size win (each .aab is ~75 MB).
*.aab
*.apk
adb_temp/
