rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: is user signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if authenticated user is admin in users collection
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users
    // Owners edit their own doc, but creator status is admin-granted only:
    // without the field guard, anyone could self-assign accountType='creator'.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (
        isAuthenticated() && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['accountType', 'creator'])
      );
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['accountType', 'creator'])
      );
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Venues
    match /venues/{venueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Creators (Affiliates)
    match /creators/{creatorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Installs (Audits Log)
    // Locked down to client-side writes. Created/validated strictly via Cloud Functions.
    match /installs/{installId} {
      allow read: if isAdmin();
      allow write: if false; 
    }

    // Pending Clicks (Attribution logs)
    // Only accessible/readable by admin for dashboard simulation.
    match /pending_clicks/{clickId} {
      allow read, write: if isAdmin();
    }

    // Stories
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    // Settings (e.g. simulation settings)
    match /settings/{settingId} {
      allow read: if isAuthenticated() || settingId == 'app_config';
      allow write: if isAdmin();
    }

    // Platform Reports
    match /reports/{reportId} {
      allow create: if isAuthenticated() 
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    // Recurring Stories
    match /recurring_stories/{scheduleId} {
      allow read, write: if isAdmin();
    }

    // Pending Events (Claude Event Curator staging area)
    match /pendingEvents/{eventId} {
      allow read, write: if isAdmin();
    }

    // ── Creator Program ──────────────────────────────────────────────────

    // Applications. Full Name is PRIVATE: readable only by the applicant and
    // admins. Owners can never change `status` — approval/rejection is
    // admin-only. Owners may update a pending application (code regeneration)
    // and re-apply after a rejection.
    match /creatorApplications/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId
        && request.resource.data.status == 'pending';
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == userId
        && request.resource.data.status == 'pending'
        && (resource.data.status == 'pending' || resource.data.status == 'rejected')
      );
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Event attendance ("I'm Going"). Visible to everyone in the app; only an
    // approved creator can declare their own attendance. Geofence verification
    // updates the creator's own doc.
    match /creatorAttendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'creator';
      allow update, delete: if isAdmin() || (
        isAuthenticated() && resource.data.userId == request.auth.uid
      );
    }
  }
}
