{
  "rules": {
    "locations": {
      ".read": "auth != null",
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    },
    "simulated_locations": {
      ".read": true,
      ".write": "auth != null"
    },
    "simulation_status": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "venue_chats": {
      ".read": "auth != null",
      "$venueId": {
        "$messageId": {
          ".write": "auth != null && (!newData.exists() || newData.child('type').val() !== 'text' || !newData.child('message').exists() || newData.child('message').val().length <= 80)"
        }
      }
    },
    "user_chats": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "$userId === auth.uid"
      }
    },
    "venue_members": {
      "$venueId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && $userId === auth.uid"
        }
      }
    },
    "venue_presence": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
